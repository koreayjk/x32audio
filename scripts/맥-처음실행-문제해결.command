#!/bin/bash
# ============================================================
#  X32 교회 음향 · 맥 첫 실행 문제 해결
#
#  다른 맥에 앱을 옮긴 뒤 "손상됐다" / "열 수 없다" / 켜자마자 꺼짐이
#  생기면, 이 파일을 더블클릭하세요. (터미널 명령 몰라도 됩니다.)
#
#  하는 일 2가지:
#   1) 인터넷/에어드랍 격리 표시 제거 (xattr -cr)
#   2) 앱 애드혹 재서명 (codesign --sign -)
# ============================================================

APP="/Applications/X32 교회 음향.app"

echo ""
echo "  X32 교회 음향 · 첫 실행 문제 해결"
echo "  --------------------------------"

if [ ! -d "$APP" ]; then
  echo "  ⚠️  앱을 찾지 못했어요:"
  echo "      $APP"
  echo ""
  echo "  먼저 dmg 를 열어 앱을 '응용 프로그램(Applications)' 폴더로"
  echo "  드래그해 설치한 뒤, 이 파일을 다시 더블클릭하세요."
  echo ""
  read -n 1 -s -r -p "  아무 키나 누르면 닫힙니다..."
  exit 1
fi

echo "  1) 격리 표시 제거 중..."
xattr -cr "$APP"

echo "  2) 앱 재서명 중..."
codesign --force --deep --sign - "$APP" 2>/dev/null

echo ""
echo "  ✅ 완료! 이제 앱을 열어보세요."
echo ""

# 바로 앱 실행 시도
open "$APP"

read -n 1 -s -r -p "  아무 키나 누르면 이 창이 닫힙니다..."
echo ""
